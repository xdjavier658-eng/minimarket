# ============================================================================
# MINIMARKET BACKEND - EJEMPLO DE CONFIGURACIÓN DE VARIABLES DE ENTORNO
# ============================================================================
# 
# INSTRUCCIONES:
# 1. Copia este archivo: cp .env.example .env
# 2. Edita .env con tus valores reales
# 3. El archivo .env NUNCA será subido a GitHub (está en .gitignore)
# 4. Reinicia el servidor para que Spring Boot lea las nuevas variables
#
# ⚠️  IMPORTANTE: Los valores aquí son DUMMY/EJEMPLO. Reemplázalos con valores reales.
# ============================================================================

# ===================================
# 📦 BASE DE DATOS (PostgreSQL)
# ===================================
# URL de conexión a la base de datos
DATABASE_URL=jdbc:postgresql://localhost:5432/minimarket_db

# Usuario de base de datos
DATABASE_USER=postgres

# Contraseña de base de datos
# REEMPLAZAR: Pon tu contraseña real de PostgreSQL
DATABASE_PASSWORD=tu_contraseña_postgres_aqui

# ===================================
# 🔐 SEGURIDAD JWT
# ===================================
# Clave secreta para firmar tokens JWT
# REEMPLAZAR: Genera una clave larga y segura (mínimo 32 caracteres)
# Puedes usar: https://www.random.org/strings/ o `openssl rand -base64 32`
JWT_SECRET=Tu_Clave_Secreta_Muy_Larga_De_Al_Menos_32_Caracteres_Cambiar_Siempre

# Tiempo de expiración del token JWT en milisegundos
# 86400000 = 24 horas, 604800000 = 7 días
JWT_EXPIRATION=86400000

# ===================================
# 💳 MERCADO PAGO
# ===================================
# Access Token de Mercado Pago (Sandbox)
# REEMPLAZAR: Ve a https://www.mercadopago.com.pe/developers/panel
# Busca: Credenciales > PRUEBA > Access Token
# Formato: APP_USR-XXXXXXXXXXXXXXXX-XXXXXXXXXXXX-XXXXXXXXXXXXXXXXXXXXXXXX
MERCADOPAGO_ACCESS_TOKEN=APP_USR-TEST-000000000000-000000-00000000000000000000000000000000-0000000

# Public Key de Mercado Pago (Sandbox)
# REEMPLAZAR: Ve a https://www.mercadopago.com.pe/developers/panel
# Busca: Credenciales > PRUEBA > Public Key
MERCADOPAGO_PUBLIC_KEY=APP_USR-TEST-000000000000-000000-00000000000000000000000000000000-0000000

# URLs de retorno después del pago (debe coincidir con lo configurado en MP)
MERCADOPAGO_SUCCESS_URL=http://localhost:3000/pago-exitoso
MERCADOPAGO_FAILURE_URL=http://localhost:3000/pago-fallido
MERCADOPAGO_PENDING_URL=http://localhost:3000/pago-pendiente

# URL del webhook para recibir notificaciones de pago
# REEMPLAZAR: Para desarrollo local, usar: https://xxxx.ngrok.io/api/mercadopago/webhook
# ngrok expone tu localhost:8080 a internet: `ngrok http 8080`
MERCADOPAGO_NOTIFICATION_URL=http://localhost:8080/api/mercadopago/webhook

# Tiempo de expiración del pago en minutos
MERCADOPAGO_EXPIRATION_MINUTES=30

# Activar modo sandbox (true) o producción (false)
# true = pruebas con dinero ficticio
# false = transacciones reales (requiere credenciales de PRODUCCIÓN)
MERCADOPAGO_SANDBOX=true

# ============================================================================
# ⚡ GUÍA RÁPIDA DE INICIO
# ============================================================================
#
# 1. CREAR ARCHIVO .env LOCAL:
#    cd minimarket_backend
#    cp .env.example .env
#
# 2. EDITAR VALORES EN .env:
#    - DATABASE_PASSWORD: tu contraseña de PostgreSQL
#    - JWT_SECRET: genera uno seguro (openssl rand -base64 32)
#    - MERCADOPAGO_ACCESS_TOKEN: desde https://www.mercadopago.com.pe/developers
#    - MERCADOPAGO_PUBLIC_KEY: desde https://www.mercadopago.com.pe/developers
#
# 3. REINICIAR BACKEND:
#    mvn spring-boot:run
#
# 4. VERIFICAR QUE FUNCIONA:
#    curl http://localhost:8080/api/payments/health
#    (Deberías ver respuesta JSON con status)
#
# ============================================================================
