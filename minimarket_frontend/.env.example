# ============================================================================
# MINIMARKET FRONTEND - EJEMPLO DE CONFIGURACIÓN DE VARIABLES DE ENTORNO
# ============================================================================
#
# INSTRUCCIONES:
# 1. Copia este archivo: cp .env.example .env
# 2. Edita .env con tus valores (especialmente URLs de API)
# 3. El archivo .env NUNCA será subido a GitHub (está en .gitignore)
# 4. Reinicia `npm run dev` para que Vite lea las nuevas variables
#
# ⚠️  IMPORTANTE: 
#    - Solo variables que comienzan con VITE_ serán expuestas al frontend
#    - Los valores aquí son DUMMY/EJEMPLO. Reemplázalos según tu ambiente.
# ============================================================================

# ===================================
# 🌐 API BACKEND
# ===================================
# URL base del API backend
# DESARROLLO: http://localhost:8080
# PRODUCCIÓN: https://api.tu-dominio.com
VITE_API_URL=http://localhost:8080

# Timeout para requests al backend (en milisegundos)
VITE_API_TIMEOUT=30000

# ===================================
# 💳 MERCADO PAGO (FRONTEND)
# ===================================
# Public Key de Mercado Pago para inicializar MercadoPago.js
# REEMPLAZAR: Ve a https://www.mercadopago.com.pe/developers/panel
# Busca: Credenciales > PRUEBA > Public Key
# Formato: APP_USR-XXXXXXXXXXXXXXXX-XXXXXXXXXXXX-XXXXXXXXXXXXXXXX
VITE_MERCADOPAGO_PUBLIC_KEY=APP_USR-TEST-000000000000-000000-00000000000000000000000000000000-0000000

# Activar modo sandbox (true) o producción (false) en MP
# true = pruebas con dinero ficticio
# false = transacciones reales
VITE_MERCADOPAGO_SANDBOX=true

# ===================================
# 🎨 APLICACIÓN
# ===================================
# Nombre de la aplicación (para logs, títulos, etc.)
VITE_APP_NAME=Minimarket

# Versión de la aplicación
VITE_APP_VERSION=1.0.0

# Ambiente: development, staging, production
VITE_ENVIRONMENT=development

# ===================================
# 📊 ANALYTICS (opcional)
# ===================================
# Habilitar o deshabilitar analytics
VITE_ENABLE_ANALYTICS=false

# ============================================================================
# ⚡ GUÍA RÁPIDA DE INICIO
# ============================================================================
#
# 1. CREAR ARCHIVO .env LOCAL:
#    cd minimarket_frontend
#    cp .env.example .env
#
# 2. EDITAR VALORES EN .env:
#    - VITE_API_URL: URL de tu backend (cambiar según ambiente)
#    - VITE_MERCADOPAGO_PUBLIC_KEY: desde https://www.mercadopago.com.pe/developers
#
# 3. REINICIAR FRONTEND:
#    npm run dev
#
# 4. USAR EN COMPONENTES:
#    import.meta.env.VITE_API_URL  // → "http://localhost:8080"
#    import.meta.env.VITE_MERCADOPAGO_PUBLIC_KEY  // → "APP_USR-..."
#
# 5. EN PRODUCCIÓN:
#    - Cambiar VITE_API_URL a URL de producción
#    - Cambiar VITE_MERCADOPAGO_SANDBOX a false
#    - Usar Public Key de PRODUCCIÓN (no PRUEBA)
#    - Ejecutar: npm run build
#
# ============================================================================
